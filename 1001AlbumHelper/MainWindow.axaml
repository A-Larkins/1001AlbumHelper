<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="_1001AlbumHelper.MainWindow"
        Width="800" Height="580" MinWidth="660" MinHeight="500"
        Title="1001 Albums Helper"
        RequestedThemeVariant="Dark">

  <Window.Background>
    <LinearGradientBrush StartPoint="0%,0%" EndPoint="30%,100%">
      <GradientStop Color="#151020" Offset="0" />
      <GradientStop Color="#0e0b09" Offset="0.45" />
      <GradientStop Color="#0b0807" Offset="1" />
    </LinearGradientBrush>
  </Window.Background>

  <Window.Styles>
    <!-- ===== Action cards ===== -->
    <Style Selector="Button.card">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="19,19" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
          <GradientStop Color="#241d17" Offset="0" />
          <GradientStop Color="#1b1511" Offset="1" />
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="#332921" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.card:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2b2219" />
      <Setter Property="BorderBrush" Value="#544133" />
    </Style>
    <Style Selector="Button.card:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.4" />
    </Style>

    <!-- The primary action -->
    <Style Selector="Button.card.hero">
      <Setter Property="Padding" Value="23,24" />
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
          <GradientStop Color="#4e3714" Offset="0" />
          <GradientStop Color="#2b2010" Offset="1" />
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="#a97c2c" />
    </Style>
    <Style Selector="Button.card.hero:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#573d16" />
      <Setter Property="BorderBrush" Value="#e0aa54" />
    </Style>

    <!-- Icon badge -->
    <Style Selector="Border.badge">
      <Setter Property="Width" Value="42" />
      <Setter Property="Height" Value="42" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Background" Value="#2e251d" />
      <Setter Property="BorderBrush" Value="#41332812" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.card.hero Border.badge">
      <Setter Property="Width" Value="48" />
      <Setter Property="Height" Value="48" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Background" Value="#6b4a17" />
    </Style>
    <Style Selector="Border.badge TextBlock">
      <Setter Property="FontSize" Value="19" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.card.hero Border.badge TextBlock">
      <Setter Property="FontSize" Value="22" />
    </Style>

    <!-- Card text -->
    <Style Selector="Button.card TextBlock.title">
      <Setter Property="Foreground" Value="#f0e5da" />
      <Setter Property="FontSize" Value="13.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.card TextBlock.desc">
      <Setter Property="Foreground" Value="#a99884" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="Margin" Value="0,4,0,0" />
      <Setter Property="LineHeight" Value="16" />
    </Style>
    <Style Selector="Button.card.hero TextBlock.title">
      <Setter Property="Foreground" Value="#f7cf90" />
      <Setter Property="FontSize" Value="16.5" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="Button.card.hero TextBlock.desc">
      <Setter Property="Foreground" Value="#c9b499" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- ===== Small ghost buttons ===== -->
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="#221b16" />
      <Setter Property="BorderBrush" Value="#3a2e25" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="11,6" />
      <Setter Property="Foreground" Value="#cbbdb0" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
      <Setter Property="BorderBrush" Value="#54453a" />
      <Setter Property="Foreground" Value="#f0e5da" />
    </Style>
    <Style Selector="Button.ghost:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.4" />
    </Style>

    <Style Selector="TextBlock.sectionLabel">
      <Setter Property="Foreground" Value="#6f6053" />
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Margin" Value="2,0,0,0" />
    </Style>
  </Window.Styles>

  <Grid Margin="24,20,24,18" RowDefinitions="Auto,Auto,*,Auto,Auto">

    <!-- ===== Header ===== -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,16">
      <Border Grid.Column="0" Width="46" Height="46" CornerRadius="23" VerticalAlignment="Center"
              Background="#111014" BorderBrush="#2a2733" BorderThickness="1">
        <Border Width="16" Height="16" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Border.Background>
            <RadialGradientBrush>
              <GradientStop Color="#f2c078" Offset="0" />
              <GradientStop Color="#a86f24" Offset="1" />
            </RadialGradientBrush>
          </Border.Background>
          <Border Width="4" Height="4" CornerRadius="2" Background="#111014"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
      </Border>

      <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0" Spacing="2">
        <TextBlock Text="1001 Albums Helper" FontSize="21" FontWeight="Bold" Foreground="#f3e9df" />
        <TextBlock Text="Rate albums and keep your Google Sheet in step"
                   FontSize="12.5" Foreground="#a99884" />
      </StackPanel>

      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <Border VerticalAlignment="Center" CornerRadius="999"
                Background="#1c1613" BorderBrush="#3a2e25" BorderThickness="1" Padding="12,7">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#7c6d60" />
            <TextBlock x:Name="StatusText" Text="Idle" FontSize="12" Foreground="#a99884" />
          </StackPanel>
        </Border>
        <Button x:Name="CheckButton" Classes="ghost" Content="Check connection"
                Tag="sync-check" Click="OnRun"
                ToolTip.Tip="Sign in and list the sheet’s tabs — a safe, read-only check." />
      </StackPanel>
    </Grid>

    <Border Grid.Row="1" Height="1" Margin="0,0,0,18">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
          <GradientStop Color="#00000000" Offset="0" />
          <GradientStop Color="#3a2e25" Offset="0.12" />
          <GradientStop Color="#3a2e25" Offset="0.88" />
          <GradientStop Color="#00000000" Offset="1" />
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- ===== Actions ===== -->
    <StackPanel Grid.Row="2" Spacing="13" VerticalAlignment="Center">

      <Button x:Name="RateNextButton" Classes="card hero" Click="OnRateNext">
        <Grid ColumnDefinitions="Auto,*">
          <Border Grid.Column="0" Classes="badge">
            <TextBlock Text="🎧" />
          </Border>
          <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
            <TextBlock Classes="title" Text="Rate the next album" />
            <TextBlock Classes="desc" Text="Walks albums with no mark yet, in list order. A ⭐ is added to your Must Hear list automatically." />
          </StackPanel>
        </Grid>
      </Button>

      <Grid ColumnDefinitions="*,*">
        <Button Grid.Column="0" x:Name="BackfillButton" Classes="card" Click="OnBackfill" Margin="0,0,6,0">
          <Grid ColumnDefinitions="Auto,*">
            <Border Grid.Column="0" Classes="badge">
              <TextBlock Text="📼" />
            </Border>
            <StackPanel Grid.Column="1" Margin="13,0,0,0" VerticalAlignment="Center">
              <TextBlock Classes="title" Text="Backfill rated ✓" />
              <TextBlock Classes="desc" Text="Score the ones marked listened but never rated." />
            </StackPanel>
          </Grid>
        </Button>

        <Button Grid.Column="1" x:Name="AddAlbumButton" Classes="card" Click="OnAddAlbum" Margin="6,0,0,0">
          <Grid ColumnDefinitions="Auto,*">
            <Border Grid.Column="0" Classes="badge">
              <TextBlock Text="➕" />
            </Border>
            <StackPanel Grid.Column="1" Margin="13,0,0,0" VerticalAlignment="Center">
              <TextBlock Classes="title" Text="Add an album" />
              <TextBlock Classes="desc" Text="Slots into your replacements list by year." />
            </StackPanel>
          </Grid>
        </Button>
      </Grid>

      <Button x:Name="SyncButton" Classes="card" Tag="sync-all" Click="OnRun">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Border Grid.Column="0" Classes="badge">
            <TextBlock Text="🔄" />
          </Border>
          <StackPanel Grid.Column="1" Margin="13,0,0,0" VerticalAlignment="Center">
            <TextBlock Classes="title" Text="Sync all" />
            <TextBlock x:Name="SyncDescText" Classes="desc"
                       Text="Reconciles both lists with the 1001 list — catches edits made in the browser." />
          </StackPanel>
          <Border Grid.Column="2" x:Name="SyncBadge" IsVisible="False" VerticalAlignment="Center"
                  CornerRadius="999" Background="#5a3a12" BorderBrush="#d8a24a" BorderThickness="1"
                  Padding="10,4" Margin="10,0,0,0">
            <TextBlock x:Name="SyncBadgeText" Text="" FontSize="11" FontWeight="SemiBold"
                       Foreground="#f7cf90" />
          </Border>
        </Grid>
      </Button>
    </StackPanel>

    <!-- ===== Log ===== -->
    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,18,0,7">
      <TextBlock Grid.Column="0" Classes="sectionLabel" Text="ACTIVITY LOG" VerticalAlignment="Center" />
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
        <TextBlock x:Name="ElapsedText" Text="" FontSize="11.5" Foreground="#6f6053" VerticalAlignment="Center" />
        <Button Classes="ghost" Content="Clear" Click="OnClearLog" />
      </StackPanel>
    </Grid>

    <Border Grid.Row="4" Height="118" CornerRadius="12" Background="#120f0e"
            BorderBrush="#282019" BorderThickness="1">
      <TextBox x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
               BorderThickness="0" Background="Transparent" Foreground="#bcae9f"
               FontFamily="Menlo,Consolas,monospace" FontSize="11.5" Padding="13,11"
               VerticalContentAlignment="Top"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               Text="Ready. Pick an action above — output streams here live." />
    </Border>
  </Grid>
</Window>
