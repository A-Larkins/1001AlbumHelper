<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="_1001AlbumHelper.MainWindow"
        Width="720" Height="620" MinWidth="600" MinHeight="500"
        Title="1001 Albums Helper"
        RequestedThemeVariant="Dark">

  <Window.Background>
    <LinearGradientBrush StartPoint="0%,0%" EndPoint="30%,100%">
      <GradientStop Color="#151020" Offset="0" />
      <GradientStop Color="#0e0b09" Offset="0.45" />
      <GradientStop Color="#0b0807" Offset="1" />
    </LinearGradientBrush>
  </Window.Background>

  <Window.Styles>
    <!-- The one big action -->
    <Style Selector="Button.hero">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="Padding" Value="20,18" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
          <GradientStop Color="#4a3411" Offset="0" />
          <GradientStop Color="#302510" Offset="1" />
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="#b3852f" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.hero:pointerover /template/ ContentPresenter">
      <Setter Property="BorderBrush" Value="#d8a24a" />
      <Setter Property="Background" Value="#4f3813" />
    </Style>
    <Style Selector="Button.hero:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45" />
    </Style>
    <Style Selector="Button.hero TextBlock.title">
      <Setter Property="Foreground" Value="#f5c985" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.hero TextBlock.desc">
      <Setter Property="Foreground" Value="#c0ad97" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,5,0,0" />
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Secondary action cards (the two raters) -->
    <Style Selector="Button.rate">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="15,13" />
      <Setter Property="CornerRadius" Value="13" />
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
          <GradientStop Color="#2a211a" Offset="0" />
          <GradientStop Color="#201913" Offset="1" />
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="#3a2e25" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.rate:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2c231c" />
      <Setter Property="BorderBrush" Value="#4a3a2c" />
    </Style>
    <Style Selector="Button.rate:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45" />
    </Style>
    <Style Selector="Button.rate TextBlock.title">
      <Setter Property="Foreground" Value="#f3e9df" />
      <Setter Property="FontSize" Value="13.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.rate TextBlock.desc">
      <Setter Property="Foreground" Value="#b3a394" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="Margin" Value="0,3,0,0" />
    </Style>

    <!-- Small ghost buttons -->
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="#241d18" />
      <Setter Property="BorderBrush" Value="#362b23" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Foreground" Value="#d8ccc0" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
      <Setter Property="BorderBrush" Value="#4a3a2c" />
    </Style>
    <Style Selector="Button.ghost:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45" />
    </Style>
  </Window.Styles>

  <Grid Margin="22,20,22,18" RowDefinitions="Auto,Auto,Auto,Auto,*">

    <!-- Header -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,14">
      <Border Grid.Column="0" Width="46" Height="46" CornerRadius="23" VerticalAlignment="Center"
              Background="#111014" BorderBrush="#2a2733" BorderThickness="1">
        <Border Width="16" Height="16" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Border.Background>
            <RadialGradientBrush>
              <GradientStop Color="#f2c078" Offset="0" />
              <GradientStop Color="#a86f24" Offset="1" />
            </RadialGradientBrush>
          </Border.Background>
          <Border Width="4" Height="4" CornerRadius="2" Background="#111014"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
      </Border>

      <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0" Spacing="2">
        <TextBlock Text="1001 Albums Helper" FontSize="21" FontWeight="Bold" Foreground="#f3e9df" />
        <TextBlock Text="Sync your “1001 Albums” lists to Google Sheets"
                   FontSize="12.5" Foreground="#b3a394" />
      </StackPanel>

      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <Border VerticalAlignment="Center" CornerRadius="999"
                Background="#1d1714" BorderBrush="#362b23" BorderThickness="1" Padding="12,7">
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#7c6d60" />
            <TextBlock x:Name="StatusText" Text="Idle" FontSize="12" Foreground="#b3a394" />
          </StackPanel>
        </Border>
        <Button x:Name="CheckButton" Classes="ghost" Content="Check connection"
                Tag="sync-check" Click="OnRun"
                ToolTip.Tip="Sign in and list the sheet’s tabs — a safe, read-only check." />
      </StackPanel>
    </Grid>

    <!-- Divider under header -->
    <Border Grid.Row="1" Height="1" Margin="0,0,0,18">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
          <GradientStop Color="#00000000" Offset="0" />
          <GradientStop Color="#3a2e25" Offset="0.15" />
          <GradientStop Color="#3a2e25" Offset="0.85" />
          <GradientStop Color="#00000000" Offset="1" />
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- Actions -->
    <StackPanel Grid.Row="2" Spacing="10">
      <Button x:Name="RateNextButton" Classes="hero" Click="OnRateNext">
        <StackPanel>
          <TextBlock Classes="title" Text="🎧  Rate the next album" />
          <TextBlock Classes="desc" Text="Steps through albums with no mark yet, in list order. A ⭐ is added to your Must Hear list automatically." />
        </StackPanel>
      </Button>

      <Grid ColumnDefinitions="*,*">
        <Button Grid.Column="0" x:Name="BackfillButton" Classes="rate" Click="OnBackfill" Margin="0,0,5,0">
          <StackPanel>
            <TextBlock Classes="title" Text="📼  Backfill ✓ albums" />
            <TextBlock Classes="desc" Text="Rate the ones you marked listened but never scored." />
          </StackPanel>
        </Button>
        <Button Grid.Column="1" x:Name="AddAlbumButton" Classes="rate" Click="OnAddAlbum" Margin="5,0,0,0">
          <StackPanel>
            <TextBlock Classes="title" Text="➕  Add an album" />
            <TextBlock Classes="desc" Text="Slots it into your replacements list by year and renumbers." />
          </StackPanel>
        </Button>
      </Grid>
    </StackPanel>

    <!-- Log header -->
    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,22,0,8">
      <TextBlock Grid.Column="0" Text="Activity log" FontSize="13" FontWeight="SemiBold"
                 Foreground="#f3e9df" VerticalAlignment="Center" />
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
        <TextBlock x:Name="ElapsedText" Text="" FontSize="11.5" Foreground="#7c6d60" VerticalAlignment="Center" />
        <Button Classes="ghost" Content="Clear" Click="OnClearLog" />
      </StackPanel>
    </Grid>

    <Border Grid.Row="4" CornerRadius="12" Background="#141010" BorderBrush="#2a211b" BorderThickness="1">
      <TextBox x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
               BorderThickness="0" Background="Transparent" Foreground="#d8ccc0"
               FontFamily="Menlo,Consolas,monospace" FontSize="12" Padding="14"
               VerticalContentAlignment="Top"
               Text="Ready. Hit “Build &amp; sync both lists” — output will stream here live." />
    </Border>
  </Grid>
</Window>
