<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="_1001AlbumHelper.MainWindow"
        Width="980" Height="700" MinWidth="780" MinHeight="580"
        Title="1001 Albums Helper"
        RequestedThemeVariant="Dark">

  <Window.Background>
    <LinearGradientBrush StartPoint="0%,0%" EndPoint="30%,100%">
      <GradientStop Color="#151020" Offset="0" />
      <GradientStop Color="#0e0b09" Offset="0.45" />
      <GradientStop Color="#0b0807" Offset="1" />
    </LinearGradientBrush>
  </Window.Background>

  <Window.Styles>
    <!-- Action "cards" -->
    <Style Selector="Button.card">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="15,13" />
      <Setter Property="CornerRadius" Value="13" />
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
          <GradientStop Color="#2a211a" Offset="0" />
          <GradientStop Color="#201913" Offset="1" />
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="#3a2e25" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.card:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2c231c" />
      <Setter Property="BorderBrush" Value="#4a3a2c" />
    </Style>
    <Style Selector="Button.card:disabled /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.45" />
    </Style>
    <Style Selector="Button.card TextBlock.title">
      <Setter Property="Foreground" Value="#f3e9df" />
      <Setter Property="FontSize" Value="13.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.card TextBlock.desc">
      <Setter Property="Foreground" Value="#b3a394" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="Margin" Value="0,3,0,0" />
    </Style>
    <!-- Highlighted "one click" card (named 'hero' to avoid Fluent's built-in .accent button style) -->
    <Style Selector="Button.card.hero">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
          <GradientStop Color="#4a3411" Offset="0" />
          <GradientStop Color="#302510" Offset="1" />
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="#b3852f" />
    </Style>
    <Style Selector="Button.card.hero:pointerover /template/ ContentPresenter">
      <Setter Property="BorderBrush" Value="#d8a24a" />
    </Style>
    <Style Selector="Button.card.hero TextBlock.title">
      <Setter Property="Foreground" Value="#f5c985" />
    </Style>

    <!-- Small ghost buttons -->
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="#241d18" />
      <Setter Property="BorderBrush" Value="#362b23" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Foreground" Value="#d8ccc0" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
      <Setter Property="BorderBrush" Value="#4a3a2c" />
    </Style>

    <Style Selector="TextBlock.sectionLabel">
      <Setter Property="Foreground" Value="#7c6d60" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="2,10,0,6" />
    </Style>
  </Window.Styles>

  <Grid Margin="22,20,22,18" RowDefinitions="Auto,Auto,*">

    <!-- Header -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,14">
      <Border Grid.Column="0" Width="46" Height="46" CornerRadius="23" VerticalAlignment="Center"
              Background="#111014" BorderBrush="#2a2733" BorderThickness="1">
        <Border Width="16" Height="16" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Border.Background>
            <RadialGradientBrush>
              <GradientStop Color="#f2c078" Offset="0" />
              <GradientStop Color="#a86f24" Offset="1" />
            </RadialGradientBrush>
          </Border.Background>
          <Border Width="4" Height="4" CornerRadius="2" Background="#111014"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
      </Border>

      <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0" Spacing="2">
        <TextBlock Text="1001 Albums Helper" FontSize="21" FontWeight="Bold" Foreground="#f3e9df" />
        <TextBlock Text="Manage your “1001 Albums You Must Hear Before You Die” lists"
                   FontSize="12.5" Foreground="#b3a394" />
      </StackPanel>

      <Border Grid.Column="2" VerticalAlignment="Center" CornerRadius="999"
              Background="#1d1714" BorderBrush="#362b23" BorderThickness="1" Padding="12,7">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#7c6d60" />
          <TextBlock x:Name="StatusText" Text="Idle" FontSize="12" Foreground="#b3a394" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Divider under header -->
    <Border Grid.Row="1" Height="1" Margin="0,0,0,14">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
          <GradientStop Color="#00000000" Offset="0" />
          <GradientStop Color="#3a2e25" Offset="0.15" />
          <GradientStop Color="#3a2e25" Offset="0.85" />
          <GradientStop Color="#00000000" Offset="1" />
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- Body -->
    <Grid Grid.Row="2" ColumnDefinitions="330,*">

      <!-- Left: actions -->
      <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="ActionsPanel" Spacing="8" Margin="0,0,4,0">
          <TextBlock Classes="sectionLabel" Text="SYNC TO GOOGLE SHEETS" Margin="2,0,0,4" />

          <Button Classes="card hero" Tag="sync-both" Click="OnRun">
            <StackPanel>
              <TextBlock Classes="title" Text="✅  Build &amp; sync BOTH to Google Sheets" />
              <TextBlock Classes="desc" Text="One click: rebuild the ‘Must Hear’ list, renumber the replacements, and write both straight into your Google Sheet." />
            </StackPanel>
          </Button>

          <Button Classes="card" Tag="sync-starred" Click="OnRun">
            <StackPanel>
              <TextBlock Classes="title" Text="⭐  Build &amp; sync ‘Must Hear’ list" />
              <TextBlock Classes="desc" Text="Rebuild the starred list and write it to its Google Sheet tab." />
            </StackPanel>
          </Button>

          <Button Classes="card" Tag="sync-replacements" Click="OnRun">
            <StackPanel>
              <TextBlock Classes="title" Text="🔢  Renumber &amp; sync replacements" />
              <TextBlock Classes="desc" Text="Renumber the replacement albums and write them to their Google Sheet tab." />
            </StackPanel>
          </Button>

          <Button Classes="card" Tag="sync-check" Click="OnRun">
            <StackPanel>
              <TextBlock Classes="title" Text="🔌  Check Google Sheets connection" />
              <TextBlock Classes="desc" Text="Sign in and list the sheet’s tabs — a safe, read-only check that everything is wired up." />
            </StackPanel>
          </Button>

          <TextBlock Classes="sectionLabel" Text="BUILD THE LISTS" />

          <Button Classes="card" Tag="download" Click="OnRun">
            <StackPanel>
              <TextBlock Classes="title" Text="⬇  1 · Download latest sheets" />
              <TextBlock Classes="desc" Text="Pull the newest versions of all your album lists from Google Sheets into the input folder." />
            </StackPanel>
          </Button>

          <Button Classes="card" Tag="starred" Click="OnRun">
            <StackPanel>
              <TextBlock Classes="title" Text="⭐  2 · Build “Albums Larkins Must Hear”" />
              <TextBlock Classes="desc" Text="Generate a list of your favourite (starred) albums from your main rated CSV." />
            </StackPanel>
          </Button>

          <Button Classes="card" Tag="renumber" Click="OnRun">
            <StackPanel>
              <TextBlock Classes="title" Text="🔢  3 · Renumber replacement albums" />
              <TextBlock Classes="desc" Text="Sort your replacement albums by year and write a clean, renumbered copy to output." />
            </StackPanel>
          </Button>

          <TextBlock Classes="sectionLabel" Text="ADVANCED" />

          <Button Classes="card" Tag="fetch" Click="OnRun">
            <StackPanel>
              <TextBlock Classes="title" Text="🌐  4 · Fetch fresh list from Discogs" />
              <TextBlock Classes="desc" Text="Download the official 1001-albums list from the Discogs API. Takes ~17 minutes — watch the log." />
            </StackPanel>
          </Button>

          <Button Classes="card" Tag="merge" Click="OnRun">
            <StackPanel>
              <TextBlock Classes="title" Text="🔀  5 · Merge ratings with Discogs list" />
              <TextBlock Classes="desc" Text="Combine the fresh Discogs list with your existing ratings into a single merged CSV." />
            </StackPanel>
          </Button>
        </StackPanel>
      </ScrollViewer>

      <!-- Right: log + files -->
      <Grid Grid.Column="1" Margin="16,0,0,0" RowDefinitions="Auto,*,Auto,Auto,170">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
          <TextBlock Grid.Column="0" Text="Activity log" FontSize="13" FontWeight="SemiBold"
                     Foreground="#f3e9df" VerticalAlignment="Center" />
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <TextBlock x:Name="ElapsedText" Text="" FontSize="11.5" Foreground="#7c6d60" VerticalAlignment="Center" />
            <Button Classes="ghost" Content="Clear" Click="OnClearLog" />
          </StackPanel>
        </Grid>

        <Border Grid.Row="1" CornerRadius="12" Background="#141010" BorderBrush="#2a211b" BorderThickness="1">
          <TextBox x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                   BorderThickness="0" Background="Transparent" Foreground="#d8ccc0"
                   FontFamily="Menlo,Consolas,monospace" FontSize="12" Padding="14"
                   VerticalContentAlignment="Top"
                   Text="Pick an action to get started. Output will stream here live." />
        </Border>

        <TextBlock Grid.Row="2" Text="Output files" FontSize="13" FontWeight="SemiBold"
                   Foreground="#f3e9df" Margin="0,16,0,8" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <Button Classes="ghost" Content="Open file" Click="OnOpenFile" />
          <Button Classes="ghost" Content="Reveal in Finder" Click="OnRevealFile" />
          <Button Classes="ghost" Content="Open output folder" Click="OnOpenOutputFolder" />
          <Button Classes="ghost" Content="Open input folder" Click="OnOpenInputFolder" />
        </StackPanel>

        <Border Grid.Row="4" CornerRadius="12" Background="#141010" BorderBrush="#2a211b" BorderThickness="1">
          <ListBox x:Name="FilesList" Background="Transparent" BorderThickness="0"
                   DoubleTapped="OnFileDoubleTapped" Foreground="#e4d8cc" FontSize="12.5" />
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
